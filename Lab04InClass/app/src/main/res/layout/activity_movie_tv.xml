<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505">

    <ImageView
        android:id="@+id/hero_backdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.58"
        android:contentDescription="@null"
        android:scaleType="centerCrop" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/tv_background_gradient" />

    <ScrollView
        android:id="@+id/content_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="64dp"
            android:paddingTop="32dp"
            android:paddingEnd="64dp"
            android:paddingBottom="40dp">

            <TextView
                android:id="@+id/app_mark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UITFLIX"
                android:textColor="#E50914"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/hero_title"
                android:layout_width="640dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="64dp"
                android:maxLines="2"
                android:textColor="#FFFFFF"
                android:textSize="44sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/hero_meta"
                android:layout_width="640dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="#E6E6E6"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/hero_overview"
                android:layout_width="620dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:ellipsize="end"
                android:lineSpacingExtra="3dp"
                android:maxLines="4"
                android:textColor="#E8E8E8"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/play_button"
                    android:layout_width="156dp"
                    android:layout_height="48dp"
                    android:background="@drawable/tv_button_focus"
                    android:focusable="true"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:text="Play"
                    android:textAllCaps="false"
                    android:textColor="@color/tv_button_text"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/more_button"
                    android:layout_width="176dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/tv_focus_card"
                    android:focusable="true"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:text="More Info"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/status_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="#BDBDBD"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="56dp"
                android:text="Because you like cinematic stories"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/favorites_row"
                android:layout_width="match_parent"
                android:layout_height="214dp"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:descendantFocusability="afterDescendants"
                android:focusable="false"
                android:overScrollMode="never" />

            <TextView
                android:id="@+id/trending_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:text="Trending from TMDB"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/trending_row"
                android:layout_width="match_parent"
                android:layout_height="214dp"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:descendantFocusability="afterDescendants"
                android:focusable="false"
                android:overScrollMode="never" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
