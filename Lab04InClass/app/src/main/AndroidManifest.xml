<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.BODY_SENSORS" />
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />

    <uses-feature
        android:name="android.software.leanback"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:label="Lab04 Combined"
        android:icon="@android:drawable/sym_def_app_icon"
        android:banner="@drawable/tv_banner"
        android:supportsRtl="true"
        android:theme="@style/Theme.Lab04Combined">

        <activity
            android:name="com.example.lab04combined.health.HealthActivity"
            android:exported="false" />

        <activity
            android:name="com.example.lab04combined.dictionary.DictionaryActivity"
            android:exported="false" />

        <activity
            android:name="com.example.lab04combined.tv.MovieTvActivity"
            android:exported="true"
            android:label="@string/title_homework"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.Lab04Combined.Tv">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.example.lab04combined.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
